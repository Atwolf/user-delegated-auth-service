# Local development configuration template.
# Copy this file to `.env` and fill in tenant-specific values locally.
# Never commit real tenant domains, client secrets, raw tokens, passwords, or user ids.

# Auth0 browser login.
AUTH0_DOMAIN=your-tenant.region.auth0.com
AUTH0_AUDIENCE=https://your-api.example.com
AUTH0_USER_CLIENT_ID=your-browser-login-client-id
AUTH0_USER_SCOPE="openid profile email read:workflow plan:workflow"
AUTH0_APP_BASE_URL=http://127.0.0.1:3000
AUTH0_CALLBACK_URL=http://127.0.0.1:3000/api/auth/callback
AUTH0_SESSION_SECRET=replace-with-at-least-32-random-bytes
INTERNAL_SERVICE_AUTH_SECRET=replace-with-a-separate-internal-signing-secret

# Auth0 Management API metadata reads. Keep these server-side only.
AUTH0_MANAGEMENT_CLIENT_ID=your-management-client-id
AUTH0_MANAGEMENT_CLIENT_SECRET=your-management-client-secret
AUTH0_MANAGEMENT_AUDIENCE=https://your-tenant.region.auth0.com/api/v2/

# Auth0 user-delegated token exchange / OBO.
AUTH0_OBO_CLIENT_ID=your-obo-client-id
AUTH0_OBO_CLIENT_SECRET=your-obo-client-secret
AUTH0_OBO_AUDIENCE=https://your-api.example.com
AUTH0_OBO_DOWNSTREAM_AUDIENCE=https://your-api.example.com
AUTH0_OBO_GRANT_TYPE=urn:ietf:params:oauth:grant-type:token-exchange
AUTH0_OBO_SUBJECT_TOKEN_TYPE=urn:ietf:params:oauth:token-type:access_token
AUTH0_OBO_REQUESTED_TOKEN_TYPE=urn:ietf:params:oauth:token-type:access_token

# Service URLs for local VM-first Compose topology.
SUPERVISOR_BASE_URL=http://127.0.0.1:8080
AGENT_SERVICE_URL=http://127.0.0.1:8090
AG_UI_GATEWAY_URL=http://127.0.0.1:8088/agent
EGRESS_GATEWAY_URL=http://127.0.0.1:8091
NEXT_PUBLIC_SIDECAR_URL=http://localhost:4319/v1/telemetry
OBSERVABILITY_SIDECAR_URL=http://127.0.0.1:4319
REDIS_URL=redis://127.0.0.1:6379/0

# Agent Service LLM and state persistence.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GOOGLE_ADK_MODEL=
AGENT_RUNTIME_TIMEOUT_SECONDS=25
AGENT_SERVICE_STORE_TTL_SECONDS=86400

# POC sample users. Use placeholders here; keep real sample credentials in ignored `.env`.
AUTH0_POC_USER_EMAIL=poc-user@example.com
AUTH0_POC_USER_ID=auth0|placeholder
AUTH0_POC_USER_CONNECTION=Username-Password-Authentication
AUTH0_POC_USER_PASSWORD=

# Legacy sample identity personas retained for compatibility tests.
AUTH0_SAMPLE_USER_IDENTITY_DEVELOPER_EMAIL=developer@example.com
AUTH0_SAMPLE_USER_IDENTITY_DEVELOPER_PASSWORD=
AUTH0_SAMPLE_USER_IDENTITY_DEVELOPER_USER_ID=auth0|developer-placeholder
AUTH0_SAMPLE_USER_IDENTITY_DEVELOPER_SCOPES="read:identity read:users read:developer_apps read:apps"
AUTH0_SAMPLE_USER_IDENTITY_DEVELOPER_TOOLS=get_identity_profile,get_developer_app
AUTH0_SAMPLE_USER_IDENTITY_BILLING_EMAIL=billing@example.com
AUTH0_SAMPLE_USER_IDENTITY_BILLING_PASSWORD=
AUTH0_SAMPLE_USER_IDENTITY_BILLING_USER_ID=auth0|billing-placeholder
AUTH0_SAMPLE_USER_IDENTITY_BILLING_SCOPES="read:identity read:users read:billing read:accounts"
AUTH0_SAMPLE_USER_IDENTITY_BILLING_TOOLS=get_identity_profile,get_account_balance
