# Copy to .env for local development. Do not commit real secret values.

# Auth0 Client Credentials sample configuration.
AUTH0_DOMAIN=samples.auth0.com
AUTH0_AUTHORIZATION_ENDPOINT=https://samples.auth0.com/authorize
AUTH0_TOKEN_ENDPOINT=https://samples.auth0.com/oauth/token
AUTH0_JWKS_ENDPOINT=https://samples.auth0.com/.well-known/jwks.json
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SCOPE="openid profile email phone address"

# Required for Auth0 Client Credentials unless the tenant has a default audience configured.
# Use the API Identifier from Auth0 Dashboard > Applications > APIs.
AUTH0_AUDIENCE=

# Supervisor/runtime settings.
SUBAGENT_DB_PATH=/data/supervisor/subagents.sqlite
OBSERVABILITY_SIDECAR_URL=http://127.0.0.1:4319
REDIS_URL=redis://127.0.0.1:6379/0
TEMPORAL_ADDRESS=127.0.0.1:7233

# Frontend/dev tooling settings.
SUPERVISOR_BASE_URL=http://127.0.0.1:8080
NEXT_PUBLIC_SIDECAR_URL=http://localhost:4319/v1/telemetry
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
